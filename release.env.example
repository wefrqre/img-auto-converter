# Copy this file to release.env and fill in your Apple Developer details.

# Required for codesign
DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"

# Required for notarytool profile setup
APPLE_ID="your-apple-id@example.com"
TEAM_ID="YOURTEAMID"
APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
KEYCHAIN_PROFILE="AC_NOTARY"

# Optional overrides
APP_PATH="dist/응용이미지자동화 변환기.app"
DMG_PATH="release/응용이미지자동화 변환기.dmg"
